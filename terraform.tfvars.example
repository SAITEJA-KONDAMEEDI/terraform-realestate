# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored - never commit it.

# --- Azure service principal credentials ---
# Create one with:
#   az login
#   az account show --query id -o tsv
#   az ad sp create-for-rbac --name "terraform-realestate-sp" --role="Contributor" --scopes="/subscriptions/<subscription_id>"
# The command prints appId, password, tenant - copy them below.
# The password is shown only once - save it somewhere safe immediately.

subscription_id = "00000000-0000-0000-0000-000000000000"
tenant_id       = "00000000-0000-0000-0000-000000000000"
client_id       = "00000000-0000-0000-0000-000000000000"
client_secret   = "your-service-principal-password-here"

# --- Networking ---

# Your current public IP in CIDR form, e.g. "203.0.113.45/32"
# Find it with: curl -4 ifconfig.me  (or in PowerShell: (Invoke-WebRequest -Uri "https://ifconfig.me").Content)
my_public_ip = "YOUR.PUBLIC.IP.HERE/32"

# --- VM / Database passwords ---
# Use two DIFFERENT strong passwords - never reuse the same one for both.

vm_admin_password    = "ChooseAStrongPassword123!"
mysql_admin_password = "ChooseADifferentStrongPassword456!"
